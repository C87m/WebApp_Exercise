@model Option04Form
@{
    ViewData["Title"] = "オプション演習-04 タグヘルパーを利用する";
}
<h2>@ViewData["Title"]</h2>
<div class="d-flex justify-content-center">
    <form asp-controller="Option04" asp-action="Result" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label asp-for="Value1" class="form-label"></label>
            <input asp-for="Value1" class="form-control" />
            <span asp-validation-for="Value1" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Value2" class="form-label"></label>
            <input asp-for="Value2" class="form-control" />
            <span asp-validation-for="Value2" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Option" class="form-label"></label>
            <select asp-for="Option" asp-items="Model.OptionsList" class="form-control"></select>
            <span asp-validation-for="Option" class="text-danger"></span>
        </div>
        <div class="text-center">
            <button type="submit" class="btn btn-primary">計算</button>
        </div>
    </form>
</div>